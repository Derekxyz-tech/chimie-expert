{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "moleculeData": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "role", "content", "timestamp"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat session between a user and the AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "updatedAt"]
    },
    "CourseFile": {
      "title": "Course File",
      "description": "A document uploaded by the user for analysis.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Conversation",
      "description": "Chat session metadata."
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a conversation."
    },
    "/users/{userId}/documents/{docId}": {
      "schema": "CourseFile",
      "description": "Uploaded course documents."
    },
    "/knowledge_base/{docId}": {
      "schema": "CourseFile",
      "description": "Global knowledge base documents provided by an admin."
    }
  }
}
